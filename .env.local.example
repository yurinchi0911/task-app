# ============================================
# .env.local.example
# → このファイルをコピーして .env.local を作成し、
#   各サービスの値を入れてください
# ============================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# Service Role（Settings > API の service_role。**クライアントに出さない**）
# Stripe Webhook が profiles を更新するのに必須
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# Stripe (stripe.com → Developers → API keys)
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx

NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

# 本番では必ず公開URL（カスタムドメイン or *.vercel.app）
